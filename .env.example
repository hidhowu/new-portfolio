NODE_ENV=development
PORT=3000

# PostgreSQL — get from Render/Railway managed Postgres
DATABASE_URL=postgresql://user:password@host:5432/portfolio_cms

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=change_me_to_a_random_64_char_base64_string
JWT_EXPIRES_IN=7d

# Cookie settings
COOKIE_DOMAIN=localhost
# Set to true in production
COOKIE_SECURE=false

# Cloudinary — from cloudinary.com dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin credentials (used only by seed script — change via UI after first login)
ADMIN_EMAIL= admin_email
ADMIN_PASSWORD= admin_password

# Public site URL (no trailing slash)
SITE_URL=http://localhost:3000

# Logging: trace | debug | info | warn | error
LOG_LEVEL=info
