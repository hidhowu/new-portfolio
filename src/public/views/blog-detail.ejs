<%- include('partials/page-head', {
  theme: typeof theme !== 'undefined' ? theme : {},
  seo: typeof seo !== 'undefined' ? seo : {},
  nav,
  hero: typeof hero !== 'undefined' ? hero : {},
  about: typeof about !== 'undefined' ? about : {},
  footer: typeof footer !== 'undefined' ? footer : {},
  cta: typeof cta !== 'undefined' ? cta : {},
  mobileMenu: typeof mobileMenu !== 'undefined' ? mobileMenu : {},
  socialLinks: typeof socialLinks !== 'undefined' ? socialLinks : [],
  featuredProject: typeof featuredProject !== 'undefined' ? featuredProject : null,
  recentPost: typeof recentPost !== 'undefined' ? recentPost : null,
  pageTitle: post.title,
  pageDesc: post.excerpt,
  pageImage: post.coverImageUrl,
  pagePath: '/blog/' + post.slug,
  ogType: 'article'
}) %>

<article style="padding-top:100px">
  <div class="container" style="max-width:780px">
    <div style="margin-bottom:32px">
      <span class="blog-tag"><%= post.category ? post.category.name : 'Article' %></span>
    </div>
    <h1 style="font-size:clamp(30px,5vw,48px);font-weight:800;letter-spacing:-0.02em;line-height:1.15;margin-bottom:20px"><%= post.title %></h1>
    <div style="display:flex;gap:16px;align-items:center;font-size:14px;color:var(--color-text-secondary);margin-bottom:40px">
      <span><%= new Date(post.publishedAt || post.createdAt).toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'}) %></span>
      <span>·</span>
      <span><%= post.readMinutes %> min read</span>
    </div>

    <% if (post.coverImageUrl) { %>
    <div style="aspect-ratio:2/1;border-radius:16px;overflow:hidden;margin-bottom:48px;background:linear-gradient(135deg,#1B6B2E,#1a3a4a)">
      <img src="<%= post.coverImageUrl %>" alt="<%= post.title %>" style="width:100%;height:100%;object-fit:cover" />
    </div>
    <% } %>

    <div class="blog-content">
      <%- contentHtml %>
    </div>

    <div style="margin-top:48px;padding-top:32px;border-top:1px solid var(--color-border)">
      <button id="like-btn" style="display:flex;align-items:center;gap:8px;padding:12px 20px;border:1.5px solid var(--color-border);border-radius:100px;font-size:14px;font-weight:600;cursor:pointer;background:transparent;transition:all 0.2s ease" onclick="this.dataset.liked==='1'?null:this.classList.add('liked')" data-post-id="<%= post.id %>" data-liked="0">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 15.5S2 11.5 2 6.5a4 4 0 017-2.65A4 4 0 0116 6.5c0 5-7 9-7 9z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
        Like this post
        <span id="like-count">(<%= post.likes %>)</span>
      </button>
    </div>

    <div style="margin-top:48px;padding:28px;background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);display:flex;gap:24px;align-items:flex-start">
      <% if (typeof hero !== 'undefined' && hero && hero.profileImageUrl) { %>
        <img src="<%= hero.profileImageUrl %>" alt="Author" style="width:72px;height:72px;border-radius:50%;object-fit:cover;object-position:top center;border:3px solid var(--color-primary);flex-shrink:0" />
      <% } else { %>
        <div style="width:72px;height:72px;border-radius:50%;background:var(--color-primary);color:#fff;display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:700;flex-shrink:0">J</div>
      <% } %>
      <div>
        <div style="font-size:11px;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-text-secondary);margin-bottom:4px">About the author</div>
        <h4 style="font-size:18px;font-weight:700;margin-bottom:8px">Josh — Josh Studios</h4>
        <p style="font-size:14px;color:var(--color-text-secondary);line-height:1.6;margin-bottom:16px">Designer and developer building thoughtful digital products that perform and scale.</p>
        <div style="display:flex;gap:12px">
          <a href="/#contact" class="btn-primary" style="padding:8px 18px;font-size:13px">Get in touch</a>
          <a href="/blog" class="btn-ghost" style="padding:7px 17px;font-size:13px">More writing</a>
        </div>
      </div>
    </div>
  </div>
</article>

<% if (relatedPosts && relatedPosts.length) { %>
<section style="padding:60px 0">
  <div class="container">
    <h3 style="font-size:20px;font-weight:700;margin-bottom:32px">Related Articles</h3>
    <div class="blog-grid">
      <% relatedPosts.forEach((rp, i) => { %>
        <a class="blog-card visible" href="/blog/<%= rp.slug %>">
          <div class="blog-card-cover" style="background:linear-gradient(135deg,#1B6B2E,#1a3a4a)">
            <% if (rp.coverImageUrl) { %>
              <img src="<%= rp.coverImageUrl %>" alt="<%= rp.title %>" loading="lazy" />
            <% } %>
          </div>
          <div class="blog-card-body">
            <div class="blog-card-tag"><%= rp.category ? rp.category.name : 'Article' %></div>
            <h5 class="blog-card-title"><%= rp.title %></h5>
            <div class="blog-card-meta"><%= new Date(rp.publishedAt || rp.createdAt).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %> · <%= rp.readMinutes %> min read</div>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<%- include('partials/page-foot', { music, socialLinks, footerSettings: typeof footer !== 'undefined' ? footer : {}, hero: typeof hero !== 'undefined' ? hero : {}, extraScript: '<script src="/static/blog-like.js"></script>' }) %>
