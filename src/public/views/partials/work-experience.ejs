<section class="section" id="experience">
  <div class="container">
    <div class="section-label">
      <span class="dot"></span>
      Work Experience
      <span class="divider"></span>
    </div>
    <div class="work-timeline">
      <% workExperience.forEach((item, i) => { %>
        <div class="work-item" data-anim style="transition-delay: <%= i * 0.1 %>s">
          <div class="work-period"><%= item.period %></div>
          <div class="work-role"><%= item.role %></div>
          <div class="work-company"><%= item.company %></div>
          <p class="work-desc"><%= item.description %></p>
        </div>
      <% }) %>
    </div>
  </div>
</section>
