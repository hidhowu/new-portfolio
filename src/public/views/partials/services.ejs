<section class="services section" id="services">
  <div class="container">
    <div class="section-label">
      <span class="dot"></span>
      Services
      <span class="divider"></span>
    </div>
    <% categories.forEach(cat => { %>
      <div class="services-category" data-anim>
        <h3 class="services-category-title"><%= cat.name %></h3>
        <div class="services-scroll">
          <% cat.subservices.forEach(sub => { %>
            <div class="service-card">
              <div class="service-card-icon">
                <% if (sub.iconUrl) { %>
                  <img src="<%= sub.iconUrl %>" alt="<%= sub.name %>" />
                <% } else { %>
                  <div class="service-card-icon-placeholder"></div>
                <% } %>
              </div>
              <div class="service-card-name"><%= sub.name %></div>
              <% if (sub.description) { %>
                <div class="service-card-desc"><%= sub.description %></div>
              <% } %>
              <% if (sub.externalUrl) { %>
                <a class="service-card-link" href="<%= sub.externalUrl %>" target="_blank" rel="noopener">View on Upwork →</a>
              <% } %>
            </div>
          <% }) %>
        </div>
      </div>
    <% }) %>
  </div>
</section>
