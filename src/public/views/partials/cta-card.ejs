<section class="section" id="contact">
  <div class="container">
    <div class="cta-card" data-anim>
      <h2 class="cta-card-heading"><%= cta.heading || 'Have a project in mind?' %></h2>
      <p class="cta-card-sub"><%= cta.subheading || "Need a website, automation, or backend solution? Let's chat and bring your vision to life." %></p>
      <a class="cta-card-btn" href="<%= cta.buttonHref || '#' %>"><%= cta.buttonLabel || 'Book a Call' %></a>
    </div>
  </div>
</section>
