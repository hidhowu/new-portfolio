  <script type="text/babel">
const { useEffect, useRef, useCallback } = React;

function BackgroundPattern({ pattern = 'dots', scrollY = 0 }) {
  const canvasRef = useRef(null);
  const mouseRef = useRef({ x: -1000, y: -1000 });
  const frameRef = useRef(null);
  const lastDrawRef = useRef(0);
  const isMobileRef = useRef(window.matchMedia('(pointer: coarse)').matches);

  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;
    const dpr = window.devicePixelRatio || 1;
    const resize = () => {
      canvas.width = window.innerWidth * dpr;
      canvas.height = window.innerHeight * dpr;
      canvas.style.width = window.innerWidth + 'px';
      canvas.style.height = window.innerHeight + 'px';
    };
    resize();
    window.addEventListener('resize', resize);
    const onMouse = (e) => { mouseRef.current = { x: e.clientX, y: e.clientY }; };
    const onTouch = (e) => {
      const t = e.touches[0];
      if (t) mouseRef.current = { x: t.clientX, y: t.clientY };
    };
    window.addEventListener('mousemove', onMouse);
    window.addEventListener('touchstart', onTouch, { passive: true });
    window.addEventListener('touchmove', onTouch, { passive: true });
    return () => {
      window.removeEventListener('resize', resize);
      window.removeEventListener('mousemove', onMouse);
      window.removeEventListener('touchstart', onTouch);
      window.removeEventListener('touchmove', onTouch);
      if (frameRef.current) cancelAnimationFrame(frameRef.current);
    };
  }, []);

  /* Continuous animation loop for all patterns */
  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;
    let running = true;
    const loop = () => {
      if (!running) return;
      const now = Date.now();
      if (now - lastDrawRef.current > 33) {
        lastDrawRef.current = now;
        const ctx = canvas.getContext('2d');
        const dpr = window.devicePixelRatio || 1;
        const w = canvas.width / dpr;
        const h = canvas.height / dpr;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        ctx.clearRect(0, 0, w, h);
        const m = mouseRef.current;
        if (pattern === 'dots') drawDotGrid(ctx, w, h, scrollY, m, isMobileRef.current);
        else if (pattern === 'diagonal') drawDiagonalLines(ctx, w, h, scrollY, m);
        else if (pattern === 'noise') drawNoiseGrain(ctx, w, h);
        else if (pattern === 'geometric') drawGeometric(ctx, w, h, scrollY, m);
      }
      frameRef.current = requestAnimationFrame(loop);
    };
    loop();
    return () => { running = false; };
  }, [pattern, scrollY]);

  return React.createElement('canvas', {
    ref: canvasRef,
    style: {
      position: 'fixed', top: 0, left: 0,
      width: '100vw', height: '100vh',
      pointerEvents: 'none', zIndex: 0
    }
  });
}

function drawDotGrid(ctx, w, h, scrollY, mouse, isMobile) {
  const spacing = 30;
  const baseRadius = 2.0;
  const scrollOffset = (scrollY * 0.12) % spacing;
  const time = Date.now() * 0.0006 + scrollY * 0.004;
  const mx = mouse.x, my = mouse.y;
  const influence = 180;

  for (let gx = 0; gx < w + spacing; gx += spacing) {
    for (let gy = -spacing; gy < h + spacing * 2; gy += spacing) {
      const y = gy + scrollOffset;
      const dx = gx - mx, dy = y - my;
      const dist = Math.sqrt(dx * dx + dy * dy);
      const prox = Math.max(0, 1 - dist / influence);
      const zoomR = baseRadius + prox * prox * 3.5;
      const wave = Math.sin(time + gx * 0.015 + gy * 0.015) * 0.3;
      const pull = prox * prox * 2;
      const angle = Math.atan2(dy, dx);
      const drawX = gx - Math.cos(angle) * pull;
      const drawY = y - Math.sin(angle) * pull;
      const r = Math.max(0.4, zoomR + wave);
      /* Mobile: clearly visible wave gradient; Desktop: higher ambient */
      const ambient = isMobile
        ? 0.28 + Math.sin(time * 0.5 + gx * 0.018 + gy * 0.018) * 0.08
        : 0.25;
      const alpha = ambient + prox * 0.22 ;
      ctx.beginPath();
      ctx.arc(drawX, drawY, r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(27, 94, 32, ${alpha})`;
      ctx.fill();
    }
  }
}

function drawDiagonalLines(ctx, w, h, scrollY, mouse) {
  const spacing = 24;
  const offset = (scrollY * 0.15) % spacing;
  const mx = mouse.x, my = mouse.y;
  const influence = 200;

  for (let i = -h; i < w + h; i += spacing) {
    const x1 = i + offset, y1 = 0;
    const x2 = i + offset + h, y2 = h;
    const midX = (x1 + x2) / 2, midY = h / 2;
    const dx = midX - mx, dy = midY - my;
    const dist = Math.sqrt(dx * dx + dy * dy);
    const prox = Math.max(0, 1 - dist / influence);
    const lineWidth = 0.6 + prox * 1.5;
    const alpha = 0.05 + prox * 0.12;

    ctx.beginPath();
    ctx.strokeStyle = `rgba(27, 94, 32, ${alpha})`;
    ctx.lineWidth = lineWidth;

    /* Subtle wave distortion */
    const wave = Math.sin(scrollY * 0.003 + i * 0.01) * 4 * prox;
    ctx.moveTo(x1 + wave, y1);
    ctx.lineTo(x2 - wave, y2);
    ctx.stroke();
  }
}

function drawNoiseGrain(ctx, w, h) {
  const imageData = ctx.createImageData(w, h);
  const data = imageData.data;
  for (let i = 0; i < data.length; i += 4) {
    const v = Math.random() * 255;
    data[i] = v; data[i + 1] = v; data[i + 2] = v;
    data[i + 3] = Math.random() * 14;
  }
  ctx.putImageData(imageData, 0, 0);
}

function drawGeometric(ctx, w, h, scrollY, mouse) {
  const size = 56;
  const offset = (scrollY * 0.06) % size;
  const mx = mouse.x, my = mouse.y;
  const influence = 200;
  const time = scrollY * 0.003;

  for (let x = -size; x < w + size * 2; x += size) {
    for (let y = -size; y < h + size * 2; y += size) {
      const cx = x + offset * 0.5;
      const cy = y + offset;

      const dx = cx - mx, dy = cy - my;
      const dist = Math.sqrt(dx * dx + dy * dy);
      const prox = Math.max(0, 1 - dist / influence);

      const baseAlpha = 0.08 + prox * 0.14;
      const lineW = 0.5 + prox * 1.2;
      const rotation = time + prox * 0.3;
      const scale = 0.38 + prox * 0.12;

      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate(rotation);
      ctx.strokeStyle = `rgba(27, 94, 32, ${baseAlpha})`;
      ctx.lineWidth = lineW;
      ctx.beginPath();
      for (let i = 0; i < 6; i++) {
        const a = (Math.PI / 3) * i - Math.PI / 6;
        const px = Math.cos(a) * size * scale;
        const py = Math.sin(a) * size * scale;
        i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
      }
      ctx.closePath();
      ctx.stroke();
      ctx.restore();
    }
  }
}

Object.assign(window, { BackgroundPattern });

  </script>

