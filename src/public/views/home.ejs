  <script type="text/babel">
const { useState, useEffect, useRef } = React;

// Global helper: read the Book-a-Call URL from CMS CTA setting.
window.bookACallHref = function () {
  return (window.__D && window.__D.cta && window.__D.cta.buttonHref) || '#contact';
};
window.isExternalHref = function (href) {
  return !!href && !href.startsWith('#') && !href.startsWith('/');
};

function Navigation({ scrolled }) {
  const [mobileOpen, setMobileOpen] = useState(false);
  const menuRef = useRef(null);

  const _defaultLinks = [
    { label: 'Home', href: '#home' },
    { label: 'About', href: '#about' },
    { label: 'Services', href: '#services' },
    { label: 'Projects', href: '/projects' },
    { label: 'Skills', href: '#skills' },
    { label: 'Blog', href: '/blog' },
  ];
  const links = (window.__D && window.__D.nav && Array.isArray(window.__D.nav.links) && window.__D.nav.links.length
    ? window.__D.nav.links.filter(l => l.isActive !== false).map(l => ({ label: l.label, href: l.href }))
    : _defaultLinks);

  const handleNav = (href) => {
    setMobileOpen(false);
    if (href.startsWith('#')) {
      const el = document.querySelector(href);
      if (el) {
        const y = el.getBoundingClientRect().top + window.pageYOffset - 80;
        window.scrollTo({ top: y, behavior: 'smooth' });
      }
    } else {
      window.location.href = href;
    }
  };

  useEffect(() => {
    if (mobileOpen) document.body.style.overflow = 'hidden';
    else document.body.style.overflow = '';
    return () => { document.body.style.overflow = ''; };
  }, [mobileOpen]);

  const navStyle = {
    position: 'fixed', top: 0, left: 0, right: 0, zIndex: 1000,
    height: 72, display: 'flex', alignItems: 'center', justifyContent: 'space-between',
    padding: '0 clamp(20px, 4vw, 48px)',
    background: scrolled ? 'rgba(247, 246, 242, 0.88)' : 'transparent',
    backdropFilter: scrolled ? 'blur(16px)' : 'none',
    WebkitBackdropFilter: scrolled ? 'blur(16px)' : 'none',
    borderBottom: scrolled ? '1px solid rgba(0,0,0,0.05)' : '1px solid transparent',
    transition: 'all 0.35s ease',
    fontFamily: 'var(--font)',
  };

  const logoStyle = {
    display: 'flex', alignItems: 'center', gap: 10, cursor: 'pointer',
    textDecoration: 'none', color: 'var(--color-text)',
  };

  const desktopLinks = {
    display: 'flex', gap: 32, alignItems: 'center',
    listStyle: 'none', margin: 0, padding: 0,
    position: 'absolute', left: '50%', transform: 'translateX(-50%)',
  };

  const linkStyle = {
    fontSize: 14, fontWeight: 500, color: 'var(--color-text-secondary)',
    textDecoration: 'none', cursor: 'pointer', transition: 'color 0.2s',
    letterSpacing: '0.01em',
  };

