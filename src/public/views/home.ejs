  <script type="text/babel">
const { useState, useEffect, useCallback } = React;

function App() {
  const tweaks = window.__TWEAKS || {};
  const font = tweaks.fontFamily || 'DM Sans';
  const pattern = tweaks.pattern || 'dots';
  const showViewAll = tweaks.showViewAllProjects !== false;
  const showSubtitle = tweaks.showSubtitle !== false;

  const [scrollY, setScrollY] = useState(0);
  const [scrolled, setScrolled] = useState(false);

  useEffect(() => {
    let ticking = false;
    const onScroll = () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          setScrollY(window.pageYOffset);
          setScrolled(window.pageYOffset > 50);
          ticking = false;
        });
        ticking = true;
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    return () => window.removeEventListener('scroll', onScroll);
  }, []);

  useEffect(() => {
    document.documentElement.style.setProperty('--font', `'${font}', sans-serif`);
    document.body.style.fontFamily = `'${font}', sans-serif`;
  }, [font]);

  return React.createElement('div', { style: { position: 'relative', minHeight: '100vh' } },
    React.createElement(BackgroundPattern, { pattern, scrollY }),
    React.createElement(Navigation, { scrolled }),
    React.createElement('main', null,
      /* ── Hero section (hero + song + gallery) ── */
      React.createElement(Hero, { showSubtitle }),
      React.createElement(SongOfMonth),
      React.createElement(GalleryStrip),

      /* ── Content sections ── */
      React.createElement(About),
      React.createElement(Services),
      React.createElement(FeaturedProjects, { showViewAll }),
      React.createElement(Skills),
      React.createElement(WorkExperience),
      React.createElement(Blog),
      React.createElement(CTASection),
      React.createElement(Footer),
    ),
  );
}

/* ── Tweaks Panel ── */
function AppWithTweaks() {
  const { useTweaks, TweaksPanel, TweakSection, TweakSelect, TweakToggle } = window;

  const [tweaks, setTweak] = useTweaks(window.TWEAK_DEFAULTS);
  window.__TWEAKS = tweaks;

  return React.createElement(React.Fragment, null,
    React.createElement(App, { key: JSON.stringify(tweaks) }),
    React.createElement(TweaksPanel, { title: 'Customization' },
      React.createElement(TweakSection, { label: 'Typography' },
        React.createElement(TweakSelect, {
          label: 'Font Family',
          value: tweaks.fontFamily,
          options: ['Inter', 'DM Sans', 'Space Grotesk', 'Manrope', 'Outfit', 'Sora'],
          onChange: (v) => setTweak('fontFamily', v),
        }),
      ),
      React.createElement(TweakSection, { label: 'Background' },
        React.createElement(TweakSelect, {
          label: 'Pattern Style',
          value: tweaks.pattern,
          options: [
            { value: 'dots', label: 'Dot Grid' },
            { value: 'diagonal', label: 'Diagonal Lines' },
            { value: 'noise', label: 'Noise Grain' },
            { value: 'geometric', label: 'Geometric' },
          ],
          onChange: (v) => setTweak('pattern', v),
        }),
      ),
      React.createElement(TweakSection, { label: 'Sections' },
        React.createElement(TweakToggle, {
          label: 'Hero Subtitle',
          value: tweaks.showSubtitle,
          onChange: (v) => setTweak('showSubtitle', v),
        }),
        React.createElement(TweakToggle, {
          label: 'View All Projects',
          value: tweaks.showViewAllProjects,
          onChange: (v) => setTweak('showViewAllProjects', v),
        }),
      ),
    ),
  );
}

Object.assign(window, { App, AppWithTweaks });

  </script>
