<!DOCTYPE html>
<html lang="en">
<%
  const _seo = (typeof seo !== 'undefined' && seo) ? seo : {};
  const siteName = _seo.siteName || _seo.siteTitle || 'Josh Studios';
  const finalTitle = _seo.siteTitle || siteName;
  const finalDesc = _seo.description || 'Designer & developer building thoughtful digital products.';
  const finalImage = _seo.ogImageUrl || null;
  const twitterImage = _seo.twitterImageUrl || finalImage;
  const canonicalUrl = _seo.canonicalBase || null;
  const twitterCard = _seo.twitterCard || (finalImage ? 'summary_large_image' : 'summary');
%>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= finalTitle %></title>
  <meta name="description" content="<%= finalDesc %>" />
  <% if (_seo.keywords && _seo.keywords.length) { %><meta name="keywords" content="<%= _seo.keywords.join(', ') %>" /><% } %>
  <% if (_seo.author) { %><meta name="author" content="<%= _seo.author %>" /><% } %>
  <% if (canonicalUrl) { %><link rel="canonical" href="<%= canonicalUrl %>" /><% } %>
  <% if (_seo.faviconUrl) { %><link rel="icon" href="<%= _seo.faviconUrl %>" /><% } %>
  <% if (_seo.googleVerification) { %><meta name="google-site-verification" content="<%= _seo.googleVerification %>" /><% } %>

  <meta property="og:title" content="<%= finalTitle %>" />
  <meta property="og:description" content="<%= finalDesc %>" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="<%= siteName %>" />
  <% if (_seo.locale) { %><meta property="og:locale" content="<%= _seo.locale %>" /><% } %>
  <% if (canonicalUrl) { %><meta property="og:url" content="<%= canonicalUrl %>" /><% } %>
  <% if (finalImage) { %><meta property="og:image" content="<%= finalImage %>" /><% } %>

  <meta name="twitter:card" content="<%= twitterCard %>" />
  <meta name="twitter:title" content="<%= finalTitle %>" />
  <meta name="twitter:description" content="<%= finalDesc %>" />
  <% if (twitterImage) { %><meta name="twitter:image" content="<%= twitterImage %>" /><% } %>
  <% if (_seo.twitterHandle) { %><meta name="twitter:site" content="<%= _seo.twitterHandle %>" /><meta name="twitter:creator" content="<%= _seo.twitterHandle %>" /><% } %>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=Manrope:wght@400;500;600;700&family=Outfit:wght@400;500;600;700&family=Sora:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    :root {
      --font: 'Inter', sans-serif;
      --color-primary: #1B6B2E;
      --color-primary-light: #2E8B3E;
      --color-primary-dark: #145222;
      --color-bg: rgba(214, 255, 249, 0.165);
      --color-surface: #FFFFFF;
      --color-text: #1A1A1A;
      --color-text-secondary: #6B6B6B;
      --color-border: #E8E6E1;
      --max-width: 1200px;
    }

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html {
      scroll-behavior: smooth;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      background: #F7F6F2;
    }

    body {
      font-family: var(--font);
      background: var(--color-bg);
      color: var(--color-text);
      line-height: 1.5;
      overflow-x: hidden;
    }

    ::selection {
      background: rgba(27, 107, 46, 0.15);
      color: var(--color-text);
    }

    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--color-border); border-radius: 3px; }

    /* ── Nav responsive ── */
    @media (max-width: 768px) {
      .nav-desktop-links { display: none !important; }
      .hamburger-btn { display: flex !important; }
    }
    @media (min-width: 769px) {
      .hamburger-btn { display: none !important; }
    }

    /* ── Gallery animations ── */
    @keyframes galleryScroll {
      from { transform: translateX(0); }
      to { transform: translateX(-25%); }
    }
    @keyframes galleryScrollRev {
      from { transform: translateX(-25%); }
      to { transform: translateX(0); }
    }

    /* ── General animations ── */
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes cursorBlink {
      50% { border-color: transparent; }
    }
    @keyframes heroFloat {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }
    @keyframes rotateBorderSpin {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }
    .profile-frame { transition: transform 0.35s ease, box-shadow 0.35s ease; cursor: default; }
    .profile-frame:hover { transform: scale(1.04); box-shadow: 0 10px 36px rgba(27,107,46,0.22); }
    @keyframes blobMorph {
      0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
      25%       { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
      50%       { border-radius: 50% 60% 30% 40% / 30% 50% 60% 50%; }
      75%       { border-radius: 70% 30% 50% 60% / 40% 70% 30% 60%; }
    }
    @keyframes blobPulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(27, 107, 46, 0.35), 0 0 24px rgba(27, 107, 46, 0.15); }
      50%       { box-shadow: 0 0 0 7px rgba(27, 107, 46, 0), 0 0 36px rgba(27, 107, 46, 0.25); }
    }

    /* ── Hover states ── */
    .nav-link:hover { color: var(--color-primary) !important; }
    .nav-cta-btn:hover { background: var(--color-primary-dark) !important; transform: translateY(-1px); }
    .hero-cta-btn:hover { background: var(--color-primary-dark) !important; transform: translateY(-1px); box-shadow: 0 4px 20px rgba(27, 107, 46, 0.25); }
    .hero-ghost-btn:hover { background: rgba(0,0,0,0.04) !important; }
    .service-card:hover { transform: translateY(-4px) !important; box-shadow: 0 8px 32px rgba(0,0,0,0.08) !important; }
    .solution-card:hover { border-color: var(--color-primary) !important; box-shadow: 0 8px 28px rgba(27,107,46,0.12) !important; transform: translateY(-6px) !important; }
    .solution-icon { transition: color 0.2s, background 0.2s; }
    .solution-card:hover .solution-icon { color: var(--color-primary) !important; background: rgba(27,107,46,0.08) !important; }
    .project-img-inner { transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94); }
    .project-card:hover .project-img-inner { transform: scale(1.06); }
    .solution-link:hover { gap: 8px; }
    .skill-tag:hover { background: var(--color-primary) !important; color: #fff !important; border-color: var(--color-primary) !important; }
    .skill-tag:hover .skill-icon { background: rgba(255,255,255,0.2) !important; }
    .project-card:hover { transform: translateY(-3px) !important; box-shadow: 0 8px 32px rgba(0,0,0,0.08) !important; }
    .project-link-btn:hover { gap: 10px !important; }
    .view-all-btn:hover { gap: 10px !important; }
    .play-btn:hover { transform: scale(1.06); }
    .blog-row:hover .blog-arrow { transform: translateX(4px); }
    .blog-row:hover h3 { color: var(--color-primary) !important; }
    .cta-main-btn:hover { transform: translateY(-2px); box-shadow: 0 4px 20px rgba(0,0,0,0.1); }
    .footer-social:hover { color: var(--color-primary) !important; background: rgba(27,107,46,0.08) !important; }

    /* ── Gallery card hover zoom ── */
    .gc-inner {
      transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      will-change: transform;
    }
    .gc-wrap:hover .gc-inner { transform: scale(1.07); }

    /* ── Hide scrollbar for horizontal scroll ── */
    .hide-scrollbar::-webkit-scrollbar { display: none; }
    .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

    /* ── Projects grid responsive ── */
    @media (max-width: 768px) {
      .projects-grid {
        grid-template-columns: 1fr !important;
        grid-template-rows: auto !important;
      }
      .projects-grid > div {
        grid-row: auto !important;
      }
      .projects-grid .project-img-wrap {
        height: auto !important;
        min-height: 0 !important;
        aspect-ratio: 16 / 9 !important;
      }
    }
    @media (min-width: 769px) and (max-width: 1024px) {
      .projects-grid {
        grid-template-columns: 1fr 1fr !important;
      }
    }

    /* ── Tweaks panel font inherit ── */
    [data-tweaks-panel] { font-family: var(--font) !important; }
  </style>
</head>
